{"operationId":"RestV10ProjectsProjectIdActionPlansPlansIdRevisePost","method":"POST","path":"/rest/v1.0/projects/{project_id}/action_plans/plans/{id}/revise","summary":"Move Action Plan back into \"Draft\"","description":"Move Action Plan Back into \"Draft\". This will remove approver and receiver signatures from the Plan, and set the status to \"draft\". Once in this state, the Plan is able to be updated.","tag":"Project Management/Action Plans/action-plans","parameters":[{"name":"project_id","in":"path","required":true,"description":"Unique identifier for the project.","schema":{"type":"integer"}},{"name":"id","in":"path","required":true,"description":"Action Plan ID","schema":{"type":"integer"}}],"responses":{"204":{"description":"No Content"},"401":{"description":"Unauthorized"},"403":{"description":"Forbidden"},"409":{"description":"Conflict"},"422":{"description":"Unprocessable Entity"}}}