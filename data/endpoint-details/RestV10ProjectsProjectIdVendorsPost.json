{"operationId":"RestV10ProjectsProjectIdVendorsPost","method":"POST","path":"/rest/v1.0/projects/{project_id}/vendors","summary":"Create project vendor","description":"Create a new Project Vendor.\n\n#### Country and State codes\nThe `country_code` and `state_code` parameter values must conform to the ISO-3166 Alpha-2 specification.\nSee [Working with Country Codes](/documentation/country-codes) for additional information.","tag":"Core/Directory/project-vendors","parameters":[{"name":"project_id","in":"path","required":true,"description":"Unique identifier for the project.","schema":{"type":"integer"}},{"name":"view","in":"query","required":false,"description":"The normal view provides what is shown below.\nThe extended view is the same as the normal view but includes children_count, legal_name, parent, and bidding.\nThe default view is normal.","schema":{"type":"string","enum":["normal","extended"]}},{"name":"run_configurable_validations","in":"query","required":false,"description":"If true, validations are run for the corresponding Configurable Field Set.","schema":{"type":"boolean","default":false}}],"responses":{"201":{"description":"Created","schema":{}},"400":{"description":"Bad Request"},"401":{"description":"Unauthorized"},"403":{"description":"Forbidden"}},"requestBody":{"contentType":"application/json","required":true,"schema":{"type":"object","required":["vendor"],"properties":{"vendor":{"type":"object","required":["name"],"properties":{"abbreviated_name":{"type":"string","description":"Abbreviated name"},"address":{"type":"string","description":"Street address"},"authorized_bidder":{"type":"boolean","description":"Authorized bidder status"},"business_phone":{"type":"string","description":"Business phone number"},"city":{"type":"string","description":"City"},"country_code":{"type":"string","description":"Country code (ISO-3166 Alpha-2 format)"},"email_address":{"type":"string","description":"Email address"},"fax_number":{"type":"string","description":"Fax number"},"is_active":{"type":"boolean","description":"Active status"},"labor_union":{"type":"string","description":"Labor union"},"license_number":{"type":"string","description":"License number"},"mobile_phone":{"type":"string","description":"Mobile phone number"},"name":{"type":"string","description":"Name"},"non_union_prevailing_wage":{"type":"boolean","description":"Non union prevailing wage status"},"notes":{"type":"string","description":"Notes (notes/keywords/tags)"},"origin_id":{"type":"string","description":"Origin ID"},"origin_data":{"type":"string","description":"Origin Data"},"origin_code":{"type":"string","description":"Origin Code"},"parent_id":{"type":"integer","description":"Parent Vendor ID. Cannot be the same as ID. Only two levels of hierarchy are supported (parent/child)."},"prequalified":{"type":"boolean","description":"Prequalified status","default":false},"primary_contact_id":{"type":"integer","description":"Primary Contact ID"},"state_code":{"type":"string","description":"State code (ISO-3166 Alpha-2 format)"},"trade_name":{"type":"string","description":"Vendor's Trade Name, also known as Doing Business As (DBA)."},"union_member":{"type":"boolean","description":"Union member status"},"website":{"type":"string","description":"Website url"},"zip":{"type":"string","description":"Zip code"}}}}}}}