{"operationId":"RestV10CoordinationIssuesStatusTotalGet","method":"GET","path":"/rest/v1.0/coordination_issues/status_total","summary":"Show Coordination Issue Count by Status","description":"This endpoint returns the status counts for Coordination Issues in a project.\nThe counts provide information about how the issues are distributed by location and assignee company.","tag":"Project Management/Coordination Issues/coordination-issue-status-totals","parameters":[{"name":"project_id","in":"query","required":true,"description":"Unique identifier for the project.","schema":{"type":"integer"}}],"responses":{"200":{"description":"OK","schema":{"type":"object","properties":{"open_count":{"type":"integer","description":"Count of issues with status 'open'"},"blocked_count":{"type":"integer","description":"Count of issues with status 'blocked'"},"unblocked_count":{"type":"integer","description":"Count of issues with status 'unblocked'"},"ready_for_review_count":{"type":"integer","description":"Count of issues with status 'ready_for_review'"},"moved_to_observation_count":{"type":"integer","description":"Count of issues with status 'moved_to_observation'"},"closed_count":{"type":"integer","description":"Count of issues with status 'closed'"}}}},"400":{"description":"Bad Request"},"401":{"description":"Unauthorized"}}}