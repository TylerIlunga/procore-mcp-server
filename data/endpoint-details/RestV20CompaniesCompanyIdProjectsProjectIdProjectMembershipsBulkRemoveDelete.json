{"operationId":"RestV20CompaniesCompanyIdProjectsProjectIdProjectMembershipsBulkRemoveDelete","method":"DELETE","path":"/rest/v2.0/companies/{company_id}/projects/{project_id}/project_memberships/bulk_remove","summary":"Bulk Remove Project Memberships","description":"Bulk Remove Project Memberships for many parties on the given Project. Currently, the maximum number of party IDs that can be processed in a single request is 1000. If more than 1000 party IDs are provided, only the first 1000 will be processed.\n\nThis endpoint can currently only be used to remove reference users from a project. It cannot be used to remove a user who has a login or to remove vendors.","tag":"Core/Directory/project-memberships","parameters":[{"name":"company_id","in":"path","required":true,"description":"Unique identifier for the company.","schema":{"type":"string"}},{"name":"project_id","in":"path","required":true,"description":"Unique identifier for the project.","schema":{"type":"string"}}],"responses":{"200":{"description":"OK","schema":{"type":"object","properties":{"data":{"type":"object","properties":{"processed_ids":{"type":"array","description":"Array of processed party ids","items":{"type":"integer","description":"Party Id"}},"skipped_ids":{"type":"array","description":"Array of skipped party ids","items":{"type":"integer","description":"Party Id"}}}}}}},"400":{"description":"Bad Request"},"401":{"description":"Unauthorized"},"403":{"description":"Forbidden"}},"requestBody":{"contentType":"application/json","required":true,"schema":{"type":"object","required":["party_ids"],"properties":{"party_ids":{"type":"array","items":{"type":"integer","description":"The ID of the Party (reference user) to be removed from the Project"}}}}}}