{"operationId":"RestV20ProjectsProjectIdDocumentsDocumentIdRevisionsGet","method":"GET","path":"/rest/v2.0/projects/{project_id}/documents/{document_id}/revisions","summary":"List of Document Revisions (Project)","description":"Return a list of the 20 most recent file versions (revisions) for a specific document in a project, sorted by created_at in descending order.","tag":"Core/Documents/documents","parameters":[{"name":"project_id","in":"path","required":true,"description":"Unique identifier for the project.","schema":{"type":"string"}},{"name":"document_id","in":"path","required":true,"description":"Unique identifier for the document (file).","schema":{"type":"string"}}],"responses":{"200":{"description":"OK","schema":{"type":"object","properties":{"data":{"type":"array","description":"Array of Document Revisions","items":{"type":"object","description":"A file version (revision) for a document","properties":{"id":{"type":"string","description":"File version id"},"prostore_id":{"type":"string","description":"Prostore file id"},"url":{"type":"string","description":"URL for the file version","format":"uri"},"file_id":{"type":"string","description":"File id (prostore file id)"},"file_name":{"type":"string","description":"Name of the file"},"file_size":{"type":"integer","description":"Size of the file in bytes"},"file_version":{"type":"integer","description":"Version number of the file"},"file_type":{"type":"string","description":"File type or extension (e.g. pdf)"},"created_by":{"description":"User who created this version"},"created_at":{"type":"string","description":"When this version was created","format":"date-time"}}}}}}},"401":{"description":"Unauthorized"},"403":{"description":"Forbidden"},"404":{"description":"Not Found"},"default":{"description":"Unexpected error"}}}